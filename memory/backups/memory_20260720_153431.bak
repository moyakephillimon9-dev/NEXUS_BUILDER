                    "code": {
                        "language": "Python",
                        "version": "1.0.0",
                        "author": "Coder AI",
                        "generated_at": "2026-07-20T15:34:24.299964",
                        "status": "INITIAL_IMPLEMENTATION_COMPLETE",
                        "project_type": "todo_app",
                        "files": [
                            "main.py"
                        ],
                        "requirements": [],
                        "source": "\"\"\"\nTask Manager Application\nAuto-generated by NEXUS Coder AI\n\"\"\"\n\nimport json\nimport uuid\nfrom datetime import datetime\nfrom pathlib import Path\n\nDATA_FILE = Path(\"tasks.json\")\n\n\ndef load_tasks() -> list:\n    \"\"\"Load all tasks from persistent storage.\"\"\"\n    if not DATA_FILE.exists():\n        return []\n    try:\n        with open(DATA_FILE) as f:\n            return json.load(f)\n    except (json.JSONDecodeError, OSError):\n        return []\n\n\ndef save_tasks(tasks: list) -> None:\n    \"\"\"Persist tasks to storage using atomic write.\"\"\"\n    tmp = DATA_FILE.with_suffix(\".tmp\")\n    with open(tmp, \"w\") as f:\n        json.dump(tasks, f, indent=2)\n    tmp.replace(DATA_FILE)\n\n\ndef create_task(title: str, priority: str = \"MEDIUM\", due_date: str = \"\") -> dict:\n    \"\"\"Create and persist a new task. Returns the created task.\"\"\"\n    if not title.strip():\n        raise ValueError(\"Task title cannot be empty.\")\n    priority = priority.upper()\n    if priority not in (\"LOW\", \"MEDIUM\", \"HIGH\", \"CRITICAL\"):\n        priority = \"MEDIUM\"\n    task = {\n        \"id\":         str(uuid.uuid4())[:8],\n        \"title\":      title.strip(),\n        \"status\":     \"PENDING\",\n        \"priority\":   priority,\n        \"due_date\":   due_date,\n        \"created_at\": datetime.utcnow().isoformat(),\n        \"updated_at\": datetime.utcnow().isoformat(),\n    }\n    tasks = load_tasks()\n    tasks.append(task)\n    save_tasks(tasks)\n    return task\n\n\ndef list_tasks(status: str = \"\") -> list:\n    \"\"\"Return all tasks, optionally filtered by status.\"\"\"\n    tasks = load_tasks()\n    if status:\n        tasks = [t for t in tasks if t[\"status\"] == status.upper()]\n    return sorted(tasks, key=lambda t: (\"LOW\",\"MEDIUM\",\"HIGH\",\"CRITICAL\").index(t.get(\"priority\",\"MEDIUM\")), reverse=True)\n\n\ndef complete_task(task_id: str) -> bool:\n    \"\"\"Mark a task as DONE. Returns True if found.\"\"\"\n    tasks = load_tasks()\n    for task in tasks:\n        if task[\"id\"] == task_id:\n            task[\"status\"]     = \"DONE\"\n            task[\"updated_at\"] = datetime.utcnow().isoformat()\n            save_tasks(tasks)\n            return True\n    return False\n\n\ndef delete_task(task_id: str) -> bool:\n    \"\"\"Delete a task by ID. Returns True if found.\"\"\"\n    tasks = load_tasks()\n    new   = [t for t in tasks if t[\"id\"] != task_id]\n    if len(new) == len(tasks):\n        return False\n    save_tasks(new)\n    return True\n\n\ndef get_summary() -> dict:\n    \"\"\"Return task count statistics.\"\"\"\n    tasks = load_tasks()\n    return {\n        \"total\":    len(tasks),\n        \"pending\":  sum(1 for t in tasks if t[\"status\"] == \"PENDING\"),\n        \"done\":     sum(1 for t in tasks if t[\"status\"] == \"DONE\"),\n        \"critical\": sum(1 for t in tasks if t[\"priority\"] == \"CRITICAL\"),\n    }\n\n\ndef run_repl():\n    \"\"\"Interactive task manager CLI.\"\"\"\n    print(\"=\" * 50)\n    print(\"  NEXUS Task Manager\")\n    print(\"  Commands: add, list, done, delete, summary, exit\")\n    print(\"=\" * 50)\n    while True:\n        try:\n            cmd = input(\"tasks> \").strip().lower()\n            if cmd == \"exit\":\n                break\n            elif cmd == \"add\":\n                title    = input(\"  Title    : \").strip()\n                priority = input(\"  Priority [LOW/MEDIUM/HIGH/CRITICAL]: \").strip() or \"MEDIUM\"\n                task     = create_task(title, priority)\n                print(f\"  Created: [{task['id']}] {task['title']}\")\n            elif cmd == \"list\":\n                for t in list_tasks():\n                    print(f\"  [{t['id']}] {t['priority']:<8} {t['status']:<10} {t['title']}\")\n            elif cmd == \"done\":\n                tid = input(\"  Task ID: \").strip()\n                print(\"  ✓ Done\" if complete_task(tid) else \"  Not found\")\n            elif cmd == \"delete\":\n                tid = input(\"  Task ID: \").strip()\n                print(\"  Deleted\" if delete_task(tid) else \"  Not found\")\n            elif cmd == \"summary\":\n                s = get_summary()\n                print(f\"  Total: {s['total']}  Pending: {s['pending']}  Done: {s['done']}  Critical: {s['critical']}\")\n            else:\n                print(\"  Unknown command.\")\n        except (KeyboardInterrupt, EOFError):\n            break\n\n\nif __name__ == \"__main__\":\n    run_repl()\n"
                    },
